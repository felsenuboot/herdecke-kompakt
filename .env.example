# Copy to .env.local for local dev. All optional locally:
#   - no DATABASE_URL  → subscriptions stored in .data/ratswatch.json
#   - no RESEND_API_KEY → alert emails are printed to the console

# Public base URL (used to build confirm/unsubscribe links in emails)
APP_URL=http://localhost:3000

# Postgres (Neon on Vercel). Leave empty locally to use the JSON file store.
DATABASE_URL=

# Resend (https://resend.com). Leave empty locally to log emails to console.
RESEND_API_KEY=
EMAIL_FROM="Digital.Herdecke <onboarding@resend.dev>"

# Shared secret Vercel Cron presents as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=

# How many months ahead to scan
SCAN_MONTHS=4

# Impressum / responsible-party contact data. Kept OUT of the public repo —
# set these in Vercel (Settings → Environment Variables) and in .env.local for
# local dev (.env.local is git-ignored). Empty values show placeholders.
# On the site these are rendered scrape-protected (no mailto:/tel:/plain string).
IMPRESSUM_NAME="Vorname Nachname"
IMPRESSUM_STREET="Straße Hausnr."
IMPRESSUM_CITY="PLZ Ort"
IMPRESSUM_PHONE="02330 0000000"
IMPRESSUM_EMAIL="impressum@example.org"

# E-mail subscription features (council alerts + Müll-Wecker reminders).
# OFF by default. Only set to "true" once Impressum, Datenschutz, a verified
# sending domain and the data-processing agreements (Resend/Neon) are in place.
# When off, the dashboard is a pure read-only public-data site (no user data).
NEXT_PUBLIC_SUBSCRIPTIONS_ENABLED=false
