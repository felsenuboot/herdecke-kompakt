# Install the local `file:` dependency (@publicplan/kern-react-kit) as a real
# copied package with its own deps (@kern-ux/native) hoisted into this tree,
# instead of a bare symlink. Turbopack can't resolve a symlinked package that
# lives outside the project root, and the symlink leaves @kern-ux/native — which
# the kit's CSS @imports — unresolved. Re-run `npm install` after updating the kit.
install-links=true
